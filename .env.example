PORT=3000
HOST=0.0.0.0
NODE_ENV=development
DATABASE_URL=postgres://postgres:password@localhost:5432/fastify_dev
JWT_SECRET=change_this_to_a_random_string_at_least_32_characters
REDIS_URL=redis://localhost:6379
# Optional — falls back to JWT_SECRET if empty
COOKIE_SECRET=
# Optional — leave empty to disable distributed tracing
OTEL_ENDPOINT=
LOG_LEVEL=info
# Optional — days before soft-deleted users are permanently purged
ACCOUNT_RETENTION_DAYS=90
