{
	"name": "fastify-api",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"build": "tsc && tsc-alias",
		"db:generate": "docker exec fastify_drizzle_studio nubx drizzle-kit generate",
		"db:migrate": "docker exec fastify_drizzle_studio node_modules/.bin/drizzle-kit migrate",
		"lint": "docker exec fastify_app nubx eslint src",
		"lint:fix": "docker exec fastify_app nubx eslint src --fix"
	},
	"dependencies": {
		"@fastify/compress": "^9.0.0",
		"@fastify/cookie": "^11.0.2",
		"@fastify/cors": "^11.2.0",
		"@fastify/env": "^7.0.0",
		"@fastify/helmet": "^13.0.2",
		"@fastify/jwt": "^10.1.0",
		"@fastify/multipart": "^10.0.0",
		"@fastify/rate-limit": "^11.0.0",
		"@fastify/redis": "^8.0.0",
		"@fastify/request-context": "^7.0.0",
		"@fastify/sensible": "^6.0.4",
		"@fastify/swagger": "^9.7.0",
		"@fastify/under-pressure": "^9.0.3",
		"@opentelemetry/auto-instrumentations-node": "^0.77.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
		"@opentelemetry/sdk-node": "^0.219.0",
		"@scalar/fastify-api-reference": "^1.59.3",
		"bcryptjs": "^3.0.3",
		"drizzle-orm": "^0.45.2",
		"fastify": "^5.8.5",
		"fastify-plugin": "^6.0.0",
		"fastify-type-provider-zod": "^6.1.0",
		"ioredis": "^5.11.1",
		"pino-pretty": "^13.1.3",
		"postgres": "^3.4.9",
		"prom-client": "^15.1.3",
		"uuidv7": "^1.2.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^9.0.0",
		"@types/node": "^25.9.3",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.5.0",
		"tsc-alias": "^1.8.17",
		"typescript": "^5.9.3",
		"vitest": "^4.1.8"
	}
}
