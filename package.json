{
	"name": "fastify-api",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/server.ts",
		"build": "tsc",
		"start": "node dist/server.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio --port 4983 --host 0.0.0.0",
		"lint": "eslint src",
		"format": "prettier --write src"
	},
	"dependencies": {
		"@fastify/cors": "^11.2.0",
		"@fastify/env": "^7.0.0",
		"@fastify/helmet": "^13.0.2",
		"@fastify/jwt": "^10.1.0",
		"@fastify/rate-limit": "^11.0.0",
		"@fastify/swagger": "^9.7.0",
		"@fastify/swagger-ui": "^6.0.0",
		"bcryptjs": "^3.0.3",
		"drizzle-orm": "^0.45.2",
		"fastify": "^5.8.5",
		"fastify-plugin": "^6.0.0",
		"fastify-type-provider-zod": "^6.1.0",
		"postgres": "^3.4.9",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/bcryptjs": "^3.0.0",
		"@types/node": "^25.9.3",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.5.0",
		"pino-pretty": "^13.1.3",
		"prettier": "^3.8.4",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vitest": "^4.1.8"
	}
}
